<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2 su MateriaClasse.getMateria() e setMateria()

        SpotBugs segnala che getter e setter espongono un oggetto mutabile (Materia).
        Per le entity JPA questo è inevitabile: Hibernate deve ricevere e restituire
        i riferimenti reali per il change tracking e il lazy loading.
        Fare una copia difensiva di una entity romperebbe il ciclo di vita di Hibernate.
    -->
    <Match>
        <Class name="it.scuola.materie_service.model.MateriaClasse"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
